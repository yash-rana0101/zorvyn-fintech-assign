      "item": [
        {
          "name": "POST /transactions (create)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const target = pm.collectionVariables.get('registeredUserId') || pm.collectionVariables.get('adminUserId');",
                  "pm.collectionVariables.set('targetUserId', target);",
                  "pm.collectionVariables.set('idempotencyKey', `pm-${Date.now()}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 201', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Transaction response shape is valid', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "  pm.expect(json.data.transaction.id).to.be.a('string');",
                  "});",
                  "pm.collectionVariables.set('transactionId', json.data.transaction.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{idempotencyKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"{{targetUserId}}\",\n  \"amount\": \"2500.00\",\n  \"type\": \"income\",\n  \"category\": \"salary\",\n  \"note\": \"Postman create transaction\",\n  \"idempotency_key\": \"{{idempotencyKey}}\"\n}",
              "options": {
