{
  "name": "finance-backend",
  "version": "1.0.0",
  "description": "High-scale Finance Data Processing & Access Control System",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/api",
    "dev:api": "npm run dev --workspace=apps/api",
    "start": "npm run start --workspace=apps/api",
    "start:api": "npm run start --workspace=apps/api",
    "test": "npm run test --workspace=apps/api",
    "lint": "npm run lint --workspace=apps/api",
    "migrate": "bash scripts/migrate.sh",
    "seed": "bash scripts/seed.sh",
    "reconcile": "node scripts/reconciliation.js",
    "rebalance-shard": "node scripts/rebalance-shard.js"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  }
}