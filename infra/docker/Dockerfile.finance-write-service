# Finance Write Service Dockerfile

FROM node:20-alpine AS deps
WORKDIR /app

COPY package.json ./
COPY apps/finance-write-service/package.json ./apps/finance-write-service/
COPY packages/ ./packages/

RUN npm install --workspace=apps/finance-write-service --include-workspace-root

FROM node:20-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production

RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 finance

COPY --from=deps /app/node_modules ./node_modules

COPY apps/finance-write-service/ ./apps/finance-write-service/
COPY packages/ ./packages/

USER finance

EXPOSE 3101

HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
  CMD wget -qO- http://localhost:3101/health || exit 1

CMD ["node", "apps/finance-write-service/src/server.js"]
